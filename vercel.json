{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 9 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/trigger-telegram",
            "destination": "/api/trigger-telegram"
        },
        {
            "source": "/api/telegram-status",
            "destination": "/api/telegram-status"
        },
        {
            "source": "/api/cron",
            "destination": "/api/cron"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}